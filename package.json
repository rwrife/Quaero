{
  "name": "quaero-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "Quaero — local-first personal indexing & search (Node.js)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean && rimraf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"packages/**/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"packages/**/src/**/*.{ts,tsx,json}\"",
    "daemon": "node packages/daemon/dist/index.js",
    "cli": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
