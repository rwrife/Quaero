<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Quaero.UI.ViewModels"
        x:Class="Quaero.UI.Views.MainWindow"
        Title="Quaero"
        RequestedThemeVariant="Light"
        Width="1280" Height="820"
        MinWidth="1000" MinHeight="620">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Arial" />
            <Setter Property="Background" Value="#F2F6FC" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2961BD" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#25578F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#3A74B4" />
            <Setter Property="BorderBrush" Value="#2C629C" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#26578E" />
            <Setter Property="BorderBrush" Value="#1F4976" />
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="#BDD0E8" />
            <Setter Property="Foreground" Value="#6C8099" />
            <Setter Property="BorderBrush" Value="#AFC5E1" />
        </Style>
        <Style Selector="Button.leftNavButton">
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="Foreground" Value="#EFF4FD" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.leftNavButton:pointerover">
            <Setter Property="Background" Value="#4C5562" />
            <Setter Property="BorderBrush" Value="#00000000" />
        </Style>
        <Style Selector="Button.leftNavButton:pressed">
            <Setter Property="Background" Value="#2961BD" />
            <Setter Property="BorderBrush" Value="#25578F" />
        </Style>
        <Style Selector="ListBox.leftNavList">
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBox.leftNavList > ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBox.leftNavList > ListBoxItem:pointerover">
            <Setter Property="Background" Value="#4C5562" />
        </Style>
        <Style Selector="ListBox.leftNavList > ListBoxItem:selected">
            <Setter Property="Background" Value="#2961BD" />
        </Style>
        <Style Selector="Border.leftPanelShell">
            <Setter Property="Background" Value="#292F38" />

            <Setter Property="Padding" Value="14" />
        </Style>
		<Style Selector="Border.rightPanelShell">
			<Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="Padding" Value="12"/>
			<Setter Property="Background" Value="#F5F6F8"/>
			<Setter Property="TextElement.Foreground" Value="#23384F"/>
		</Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FAFCFF" />
            <Setter Property="BorderBrush" Value="#D7E2F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </Window.Styles>

    <DockPanel>


        <Grid ColumnDefinitions="320,6,*">
            <Border Grid.Column="0" Classes="leftPanelShell">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Quaero" Foreground="#EFF4FD" FontSize="26" FontWeight="SemiBold" />
                        <TextBlock Text="Local Search Workspace" Foreground="#9CB3D8" FontSize="12" />
                        <Border Height="1" Background="#3B4350" Margin="0,10,0,0" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,12,0,0">
                        <Button Classes="leftNavButton" Content="New Search" Click="OnNewSearchClicked" />
                        <Button Classes="leftNavButton" Content="New Chat" Click="OnNewChatClicked" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="10">
                            <Button x:Name="DataSourcesHeaderButton"
                                    Classes="leftNavButton">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <PathIcon Data="M12,3C7.58,3 4,4.79 4,7V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V7C20,4.79 16.42,3 12,3ZM12,5C15.31,5 18,5.9 18,7C18,8.1 15.31,9 12,9C8.69,9 6,8.1 6,7C6,5.9 8.69,5 12,5ZM12,15C8.69,15 6,14.1 6,13V10.91C7.38,11.78 9.54,12.3 12,12.3C14.46,12.3 16.62,11.78 18,10.91V13C18,14.1 15.31,15 12,15ZM12,19C8.69,19 6,18.1 6,17V14.91C7.38,15.78 9.54,16.3 12,16.3C14.46,16.3 16.62,15.78 18,14.91V17C18,18.1 15.31,19 12,19Z"
                                                  Width="14"
                                                  Height="14"
                                                  Foreground="#BFD0EA" />
                                        <TextBlock Text="DATA SOURCES" Foreground="#BFD0EA" FontWeight="SemiBold" FontSize="12" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <StackPanel x:Name="DataSourcesSectionPanel" Spacing="8" Margin="0,8,0,0" MaxHeight="0" Opacity="0" IsHitTestVisible="False" ClipToBounds="True">
                                <StackPanel.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.22" />
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                    </Transitions>
                                </StackPanel.Transitions>
                                <Button Content="+ Add Data Source" Click="OnAddDataSourceClicked" />
                                <ListBox x:Name="DataSourcesList"
                                         Classes="leftNavList"
                                         ItemsSource="{Binding DataSourcesVM.DataSources}"
                                         SelectionChanged="OnDataSourcesSelectionChanged"
                                         Background="#00000000"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="12,8" HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding Name}" Foreground="#EFF4FD" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding PluginName}" Foreground="#C6D9F5" FontSize="11" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <TextBlock Text="SEARCH HISTORY" Foreground="#BFD0EA" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,0" />
                            <ListBox x:Name="SearchHistoryList"
                                     Classes="leftNavList"
                                     ItemsSource="{Binding SearchHistory}"
                                     SelectionChanged="OnSearchHistorySelectionChanged"
                                     Background="#00000000"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="12,8" Spacing="2" HorizontalAlignment="Stretch">
                                            <TextBlock Text="{Binding Query}" Foreground="#EFF4FD" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ResultLabel}" Foreground="#C6D9F5" FontSize="11" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="CHAT HISTORY" Foreground="#BFD0EA" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,0" />
                            <ListBox x:Name="ChatHistoryList"
                                     Classes="leftNavList"
                                     ItemsSource="{Binding ChatHistory}"
                                     SelectionChanged="OnChatHistorySelectionChanged"
                                     Background="#00000000"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="12,8" Spacing="2" HorizontalAlignment="Stretch">
                                            <TextBlock Text="{Binding Prompt}" Foreground="#EFF4FD" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ResultLabel}" Foreground="#C6D9F5" FontSize="11" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Height="1" Background="#3B4350" Margin="0,8,0,0" />
							<Button x:Name="SettingsNavButton"
                                    Classes="leftNavButton"
                                    Click="OnOpenSettingsClicked">
								<Button.Content>
									<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
										<TextBlock Text="SETTINGS" Foreground="#BFD0EA" FontWeight="SemiBold" FontSize="12" />
									</StackPanel>
								</Button.Content>
							</Button>

						</StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#3B4350"
                          ShowsPreview="True" />

            <Border Classes="rightPanelShell" Grid.Column="2">
                <Grid>
                    <!-- Workspace Pane -->
                    <ScrollViewer x:Name="WorkspacePane" IsVisible="True">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Welcome back. Search or chat with your local index."
                                           FontSize="30" FontWeight="SemiBold" Foreground="#1B2A43" />
                                <TextBlock Text="Run fast retrieval, inspect ranked documents, or chat over indexed context."
                                           Foreground="#526782" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton GroupName="ExperienceMode"
                                             Content="Search"
                                             IsChecked="{Binding IsSearchMode, Mode=OneWay}"
                                             Checked="OnSearchModeChecked" />
                                <RadioButton GroupName="ExperienceMode"
                                             Content="Chat"
                                             IsChecked="{Binding IsChatMode, Mode=OneWay}"
                                             Checked="OnChatModeChecked" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding PrimaryInputText, Mode=TwoWay}"
                                         Watermark="{Binding PrimaryInputPlaceholder}"
                                         Padding="14,12"
                                         FontSize="15"
                                         KeyDown="OnPrimaryInputKeyDown" />
                                <Button Grid.Column="1"
                                        Content="{Binding PrimaryActionText}"
                                        Click="OnSubmitPrimaryInputClicked"
                                        Padding="16,8"
                                        Margin="10,0,0,0" />
                            </Grid>

                            <Grid IsVisible="{Binding IsSearchMode}" ColumnDefinitions="44*,56*" MinHeight="380">
                                <Border Grid.Column="0" Classes="card" Padding="10" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="Ranked Results" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                                        <ListBox ItemsSource="{Binding SearchResults}"
                                                 SelectedItem="{Binding SelectedResult}"
                                                 BorderThickness="0"
                                                 Background="#00000000">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#EEF4FC" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Document.Title}" FontWeight="SemiBold"
                                                                       FontSize="14" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Document.Summary}" Foreground="#556C8A"
                                                                       FontSize="12" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock FontSize="11" Foreground="#2A629D">
                                                                <Run Text="{Binding Document.Provider}" />
                                                                <Run Text=" · " />
                                                                <Run Text="{Binding Document.Type}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card" Padding="16">
                                    <ScrollViewer>
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="{Binding SelectedResult.Document.Title}" FontSize="22"
                                                       FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SelectedResult.Document.Location}" Foreground="#1F64A8"
                                                       FontSize="12" TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock FontSize="12" Foreground="#5A708A">
                                                    <Run Text="Provider: " />
                                                    <Run Text="{Binding SelectedResult.Document.Provider}" />
                                                </TextBlock>
                                                <TextBlock FontSize="12" Foreground="#5A708A">
                                                    <Run Text="Type: " />
                                                    <Run Text="{Binding SelectedResult.Document.Type}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Separator />
                                            <TextBlock Text="{Binding SelectedResult.Document.Summary}" TextWrapping="Wrap"
                                                       Foreground="#334963" FontSize="13" />
                                            <TextBlock Text="{Binding SelectedResult.Document.Content}" TextWrapping="Wrap"
                                                       FontSize="12" Foreground="#4A5F79" MaxLines="18" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>

                            <Grid IsVisible="{Binding IsChatMode}" RowDefinitions="*,Auto" MinHeight="380">
                                <Border Grid.Row="0" Classes="card" Padding="12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ChatMessages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#EEF4FC" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Foreground="#2B4E77" />
                                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#30465F" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <Border Grid.Row="1" Classes="card" Padding="12" Margin="0,12,0,0">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Context documents used in the latest response"
                                                   FontWeight="SemiBold" FontSize="13" />
                                        <ListBox ItemsSource="{Binding SearchResults}" BorderThickness="0" Background="#00000000">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Document.Title}" Margin="0,2"
                                                               Foreground="#385978" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Data Source Pane -->
                    <Grid x:Name="DataSourcePane" IsVisible="False" RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0" Spacing="10">
                            <TextBlock Text="{Binding SelectedDataSource.Name}" FontSize="28" FontWeight="SemiBold" />
                            <TextBlock FontSize="13" Foreground="#526782">
                                <Run Text="{Binding SelectedDataSource.PluginName}" />
                                <Run Text=" · " />
                                <Run Text="{Binding SelectedDataSource.StatusText}" />
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Edit" Click="OnEditDataSourceClicked" />
                                <Button Content="Remove" Click="OnRemoveDataSourceClicked" />
                                <Button Content="Enable / Disable" Click="OnToggleDataSourceClicked" />
                                <Button Content="Run This Source" Click="OnRunSelectedClicked" />
                                <Button Content="Refresh Files" Click="OnRefreshDataSourceFilesClicked" />
                            </StackPanel>

                            <Border Background="#EEF4FC" CornerRadius="10" Padding="12">
                                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Schedule" FontWeight="SemiBold" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDataSource.CronSchedule}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Enabled" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDataSource.EnabledText}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Data Source ID" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDataSource.Id}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Indexed Items" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDataSourceIndexedItemCountText}" Margin="0,8,0,0" />
                                </Grid>
                            </Border>

                            <Border Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" />
                                    <ItemsControl ItemsSource="{Binding SelectedDataSource.Model.Settings}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="200,*" Margin="0,2">
                                                    <TextBlock Grid.Column="0" Text="{Binding Key}" FontWeight="SemiBold" Foreground="#344D6A" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#516B88" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="1" Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0">
                            <Grid RowDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Row="0" Text="Indexed Files" FontSize="16" FontWeight="SemiBold" />
                                <ScrollViewer x:Name="DataSourceFilesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" ScrollChanged="OnDataSourceFilesScrollChanged">
                                    <ListBox x:Name="DataSourceIndexedFilesList" ItemsSource="{Binding SelectedDataSourceIndexedFiles}" SelectionChanged="OnDataSourceIndexedFilesSelectionChanged" BorderThickness="0" Background="#00000000">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#EEF4FC" CornerRadius="8" Padding="8" Margin="0,0,10,10" MinWidth="200">
                                                    <StackPanel Spacing="3">
                                                        <TextBlock Text="{Binding Document.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Document.Location}" FontSize="11" Foreground="#436489" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock FontSize="11" Foreground="#4F6A87">
                                                            <Run Text="{Binding Document.Provider}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding Document.Type}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Loading more..." IsVisible="{Binding IsLoadingDataSourceFiles}" Foreground="#526782" />
                                    <Button Content="Load More" Click="OnLoadMoreDataSourceFilesClicked" IsVisible="{Binding HasMoreDataSourceFiles}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Indexed File Pane -->
                    <ScrollViewer x:Name="IndexedFilePane" IsVisible="False">
                        <StackPanel Spacing="10">
                            <Button Content="← Back" HorizontalAlignment="Left" Click="OnBackToPreviousPaneClicked" IsVisible="{Binding CanGoBack}" />
                            <TextBlock Text="{Binding SelectedIndexedFile.Document.Title}" FontSize="28" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedIndexedFile.Document.Location}" FontSize="13" Foreground="#1F64A8" />

                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock FontSize="12" Foreground="#526782">
                                    <Run Text="Provider: " />
                                    <Run Text="{Binding SelectedIndexedFile.Document.Provider}" />
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#526782">
                                    <Run Text="Type: " />
                                    <Run Text="{Binding SelectedIndexedFile.Document.Type}" />
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#526782">
                                    <Run Text="Machine: " />
                                    <Run Text="{Binding SelectedIndexedFile.Document.Machine}" />
                                </TextBlock>
                            </StackPanel>

                            <Border Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Summary" FontWeight="SemiBold" FontSize="15" />
                                    <TextBlock Text="{Binding SelectedIndexedFile.Document.Summary}" TextWrapping="Wrap" Foreground="#394F69" />
                                    <Separator />
                                    <TextBlock Text="Content Preview" FontWeight="SemiBold" FontSize="15" />
                                    <TextBlock Text="{Binding SelectedIndexedFile.Document.Content}" TextWrapping="Wrap" Foreground="#445B75" MaxLines="24" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Search History Pane -->
                    <StackPanel x:Name="SearchHistoryPane" IsVisible="False" Spacing="12">
                        <TextBlock Text="Search History Entry" FontSize="28" FontWeight="SemiBold" />
                        <Border Background="#EEF4FC" CornerRadius="10" Padding="12">
                            <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Query" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedSearchHistory.Query}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Executed" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedSearchHistory.RanAt, StringFormat='{}{0:f}'}" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Results" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedSearchHistory.ResultLabel}" Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                        <Button Content="Run This Search Again" HorizontalAlignment="Left" Click="OnRerunSearchHistoryClicked" />
                    </StackPanel>

                    <!-- Chat History Pane -->
                    <StackPanel x:Name="ChatHistoryPane" IsVisible="False" Spacing="12">
                        <TextBlock Text="Chat History Entry" FontSize="28" FontWeight="SemiBold" />
                        <Border Background="#EEF4FC" CornerRadius="10" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Prompt" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedChatHistory.Prompt}" TextWrapping="Wrap" Foreground="#324A65" />
                                <Separator />
                                <TextBlock Text="Response Snapshot" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedChatHistory.Response}" TextWrapping="Wrap" Foreground="#324A65" />
                                <TextBlock FontSize="12" Foreground="#5A708A">
                                    <Run Text="{Binding SelectedChatHistory.ResultLabel}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding SelectedChatHistory.RanAt, StringFormat='{}{0:f}'}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Button Content="Reuse Prompt In Chat" HorizontalAlignment="Left" Click="OnReuseChatPromptClicked" />
                    </StackPanel>

                    <!-- Settings Pane -->
                    <ScrollViewer x:Name="SettingsPane" IsVisible="False" DataContext="{Binding SettingsVM}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />

                            <Border Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Indexer Service" FontSize="18" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Content="{Binding StartStopButtonText}" Click="OnToggleIndexerClicked" />
                                        <Border Background="#E3ECFA" Padding="8,4" CornerRadius="6">
                                            <TextBlock Text="{Binding IndexerStatusText}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Indexer Output" FontWeight="SemiBold" />
                                    <Border Background="#152131" CornerRadius="6" Padding="10" MaxHeight="220">
                                        <ScrollViewer>
                                            <TextBlock Text="{Binding IndexerOutput}" FontFamily="Consolas"
                                                       Foreground="#D5E2F3" FontSize="11" TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Paths" FontSize="18" FontWeight="SemiBold" />
                                    <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Database" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DatabasePath}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Plugins" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PluginsDirectory}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Data Sources Config" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DataSourcesConfigPath}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Indexer Executable" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding IndexerExePath}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Index Maintenance" FontSize="18" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Compact Index" Click="OnCompactClicked" />
                                        <Button Content="Index All Now" Click="OnIndexAllClicked" />
                                        <Button Content="Refresh Sources" Click="OnRefreshClicked" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
