<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Quaero.UI.ViewModels"
        xmlns:components="using:Quaero.UI.Views.Components"
        xmlns:panes="using:Quaero.UI.Views.Panes"
        x:Class="Quaero.UI.Views.MainWindow"
        Title="Quaero"
        RequestedThemeVariant="Light"
        Width="1280" Height="820"
        MinWidth="1000" MinHeight="620">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Arial" />
            <Setter Property="Background" Value="#F2F6FC" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2961BD" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#25578F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#3A74B4" />
            <Setter Property="BorderBrush" Value="#2C629C" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#26578E" />
            <Setter Property="BorderBrush" Value="#1F4976" />
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Background" Value="#BDD0E8" />
            <Setter Property="Foreground" Value="#6C8099" />
            <Setter Property="BorderBrush" Value="#AFC5E1" />
        </Style>
        <Style Selector="Button.leftNavButton">
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="Foreground" Value="#EFF4FD" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.leftNavButton:pointerover">
            <Setter Property="Background" Value="#4C5562" />
            <Setter Property="BorderBrush" Value="#00000000" />
        </Style>
        <Style Selector="Button.leftNavButton:pressed">
            <Setter Property="Background" Value="#2961BD" />
            <Setter Property="BorderBrush" Value="#25578F" />
        </Style>
        <Style Selector="ListBox.leftNavList">
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBox.leftNavList > ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBox.leftNavList > ListBoxItem:pointerover">
            <Setter Property="Background" Value="#4C5562" />
        </Style>
        <Style Selector="ListBox.leftNavList > ListBoxItem:selected">
            <Setter Property="Background" Value="#2961BD" />
        </Style>
        <Style Selector="Border.leftPanelShell">
            <Setter Property="Background" Value="#292F38" />

            <Setter Property="Padding" Value="14" />
        </Style>
		<Style Selector="Border.rightPanelShell">
			<Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="Padding" Value="12"/>
			<Setter Property="Background" Value="#F5F6F8"/>
			<Setter Property="TextElement.Foreground" Value="#23384F"/>
		</Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FAFCFF" />
            <Setter Property="BorderBrush" Value="#D7E2F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <Grid ColumnDefinitions="320,6,*">
            <components:LeftNavPanel x:Name="LeftNavPanel" Grid.Column="0" />
            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#3B4350"
                          ShowsPreview="True" />

            <Border Classes="rightPanelShell" Grid.Column="2">
                <Grid>
                    <panes:WorkspacePaneView x:Name="WorkspacePane" IsVisible="True" />
                    <panes:DataSourcePaneView x:Name="DataSourcePane" IsVisible="False" />
                    <panes:IndexedFilePaneView x:Name="IndexedFilePane" IsVisible="False" />
                    <panes:SearchHistoryPaneView x:Name="SearchHistoryPane" IsVisible="False" />
                    <panes:ChatHistoryPaneView x:Name="ChatHistoryPane" IsVisible="False" />
                    <panes:SettingsPaneView x:Name="SettingsPane" IsVisible="False" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
