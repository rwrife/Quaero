<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Quaero.UI.Views.Panes.DataSourcePaneView">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="{Binding SelectedDataSource.Name}" FontSize="28" FontWeight="SemiBold" />
            <TextBlock FontSize="13" Foreground="#526782">
                <Run Text="{Binding SelectedDataSource.PluginName}" />
                <Run Text=" · " />
                <Run Text="{Binding SelectedDataSource.StatusText}" />
            </TextBlock>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Edit" Click="OnEditDataSourceClicked" />
                <Button Content="Remove" Click="OnRemoveDataSourceClicked" />
                <Button Content="Enable / Disable" Click="OnToggleDataSourceClicked" />
                <Button Content="Run This Source" Click="OnRunSelectedClicked" />
                <Button Content="Refresh Files" Click="OnRefreshDataSourceFilesClicked" />
            </StackPanel>

            <Border Background="#EEF4FC" CornerRadius="10" Padding="12">
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Schedule" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDataSource.CronSchedule}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Enabled" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDataSource.EnabledText}" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Data Source ID" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedDataSource.Id}" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Indexed Items" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedDataSourceIndexedItemCountText}" Margin="0,8,0,0" />
                </Grid>
            </Border>

            <Border Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding SelectedDataSource.Model.Settings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="200,*" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="{Binding Key}" FontWeight="SemiBold" Foreground="#344D6A" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#516B88" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Grid.Row="0" Text="Indexed Files" FontSize="16" FontWeight="SemiBold" />
                <ScrollViewer x:Name="DataSourceFilesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" ScrollChanged="OnDataSourceFilesScrollChanged">
                    <ListBox x:Name="DataSourceIndexedFilesList" ItemsSource="{Binding SelectedDataSourceIndexedFiles}" SelectionChanged="OnDataSourceIndexedFilesSelectionChanged" BorderThickness="0" Background="#00000000">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#EEF4FC" CornerRadius="8" Padding="8" Margin="0,0,10,10" MinWidth="200">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding Document.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Document.Location}" FontSize="11" Foreground="#436489" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Foreground="#4F6A87">
                                            <Run Text="{Binding Document.Provider}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding Document.Type}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Loading more..." IsVisible="{Binding IsLoadingDataSourceFiles}" Foreground="#526782" />
                    <Button Content="Load More" Click="OnLoadMoreDataSourceFilesClicked" IsVisible="{Binding HasMoreDataSourceFiles}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
