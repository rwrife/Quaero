<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Quaero.UI.Views.Panes.WorkspacePaneView">
    <ScrollViewer>
        <StackPanel Spacing="14">
            <StackPanel Spacing="4">
                <TextBlock Text="Welcome back. Search or chat with your local index."
                           FontSize="30" FontWeight="SemiBold" Foreground="#1B2A43" />
                <TextBlock Text="Run fast retrieval, inspect ranked documents, or chat over indexed context."
                           Foreground="#526782" FontSize="13" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <RadioButton GroupName="ExperienceMode"
                             Content="Search"
                             IsChecked="{Binding IsSearchMode, Mode=OneWay}"
                             Checked="OnSearchModeChecked" />
                <RadioButton GroupName="ExperienceMode"
                             Content="Chat"
                             IsChecked="{Binding IsChatMode, Mode=OneWay}"
                             Checked="OnChatModeChecked" />
            </StackPanel>

            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding PrimaryInputText, Mode=TwoWay}"
                         Watermark="{Binding PrimaryInputPlaceholder}"
                         Padding="14,12"
                         FontSize="15"
                         KeyDown="OnPrimaryInputKeyDown" />
                <Button Grid.Column="1"
                        Content="{Binding PrimaryActionText}"
                        Click="OnSubmitPrimaryInputClicked"
                        Padding="16,8"
                        Margin="10,0,0,0" />
            </Grid>

            <Grid IsVisible="{Binding IsSearchMode}" ColumnDefinitions="44*,56*" MinHeight="380">
                <Border Grid.Column="0" Classes="card" Padding="10" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Ranked Results" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                        <ListBox ItemsSource="{Binding SearchResults}"
                                 SelectedItem="{Binding SelectedResult}"
                                 BorderThickness="0"
                                 Background="#00000000">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EEF4FC" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Document.Title}" FontWeight="SemiBold"
                                                       FontSize="14" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Document.Summary}" Foreground="#556C8A"
                                                       FontSize="12" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="11" Foreground="#2A629D">
                                                <Run Text="{Binding Document.Provider}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding Document.Type}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="16">
                    <ScrollViewer>
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding SelectedResult.Document.Title}" FontSize="22"
                                       FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedResult.Document.Location}" Foreground="#1F64A8"
                                       FontSize="12" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock FontSize="12" Foreground="#5A708A">
                                    <Run Text="Provider: " />
                                    <Run Text="{Binding SelectedResult.Document.Provider}" />
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#5A708A">
                                    <Run Text="Type: " />
                                    <Run Text="{Binding SelectedResult.Document.Type}" />
                                </TextBlock>
                            </StackPanel>
                            <Separator />
                            <TextBlock Text="{Binding SelectedResult.Document.Summary}" TextWrapping="Wrap"
                                       Foreground="#334963" FontSize="13" />
                            <TextBlock Text="{Binding SelectedResult.Document.Content}" TextWrapping="Wrap"
                                       FontSize="12" Foreground="#4A5F79" MaxLines="18" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid IsVisible="{Binding IsChatMode}" RowDefinitions="*,Auto" MinHeight="380">
                <Border Grid.Row="0" Classes="card" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ChatMessages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EEF4FC" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Foreground="#2B4E77" />
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#30465F" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="1" Classes="card" Padding="12" Margin="0,12,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Context documents used in the latest response"
                                   FontWeight="SemiBold" FontSize="13" />
                        <ListBox ItemsSource="{Binding SearchResults}" BorderThickness="0" Background="#00000000">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Document.Title}" Margin="0,2"
                                               Foreground="#385978" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
