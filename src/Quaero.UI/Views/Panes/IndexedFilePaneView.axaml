<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Quaero.UI.Views.Panes.IndexedFilePaneView">
    <ScrollViewer>
        <StackPanel Spacing="10">
            <Button Content="← Back" HorizontalAlignment="Left" Click="OnBackToPreviousPaneClicked" IsVisible="{Binding CanGoBack}" />
            <TextBlock Text="{Binding SelectedIndexedFile.Document.Title}" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding SelectedIndexedFile.Document.Location}" FontSize="13" Foreground="#1F64A8" />

            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock FontSize="12" Foreground="#526782">
                    <Run Text="Provider: " />
                    <Run Text="{Binding SelectedIndexedFile.Document.Provider}" />
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#526782">
                    <Run Text="Type: " />
                    <Run Text="{Binding SelectedIndexedFile.Document.Type}" />
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#526782">
                    <Run Text="Machine: " />
                    <Run Text="{Binding SelectedIndexedFile.Document.Machine}" />
                </TextBlock>
            </StackPanel>

            <Border Background="#F4F8FE" BorderBrush="#D7E2F2" BorderThickness="1" CornerRadius="10" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding SelectedIndexedFile.Document.Content}" TextWrapping="Wrap" Foreground="#445B75" MaxLines="24" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
